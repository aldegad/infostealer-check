{
  "macos": {
    "browsers": {
      "chrome": [
        "~/Library/Application Support/Google/Chrome/Default/Login Data",
        "~/Library/Application Support/Google/Chrome/Default/Cookies",
        "~/Library/Application Support/Google/Chrome/Default/Web Data"
      ],
      "firefox": [
        "~/Library/Application Support/Firefox/Profiles/*.default-release/logins.json",
        "~/Library/Application Support/Firefox/Profiles/*.default-release/cookies.sqlite",
        "~/Library/Application Support/Firefox/Profiles/*.default/logins.json",
        "~/Library/Application Support/Firefox/Profiles/*.default/cookies.sqlite"
      ],
      "safari": [
        "~/Library/Safari/History.db",
        "~/Library/Safari/Cookies/Cookies.binarycookies",
