        "~/Library/Application Support/Arc/User Data/Default/Local Extension Settings/nkbihfbeogaeaoehlefnkodbefgpgknn"
      ],
      "exodus": [
        "~/Library/Application Support/Exodus",
        "~/Library/Application Support/exodus.wallet"
      ],
      "phantom": [
        "~/Library/Application Support/Google/Chrome/Default/Local Extension Settings/bfnaelmomeimhlpmgjnjophhpkkoljpa",
        "~/Library/Application Support/BraveSoftware/Brave-Browser/Default/Local Extension Settings/bfnaelmomeimhlpmgjnjophhpkkoljpa",
        "~/Library/Application Support/Arc/User Data/Default/Local Extension Settings/bfnaelmomeimhlpmgjnjophhpkkoljpa"
      ]
    },
    "sensitive_files": {
