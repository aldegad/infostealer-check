        "~/**/.env",
        "~/**/.env.*"
      ],
      "aws_credentials": [
        "~/.aws/credentials"
      ],
      "vpn_configs": {
        "openvpn": [
          "~/Library/Application Support/OpenVPN Connect/profiles/*.ovpn",
